# Optional local-only variables for the one-time ElevenLabs voice generation job.
# Do not commit your real key. The live site does not need these values.
ELEVENLABS_API_KEY=
ELEVENLABS_ENGLISH_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.2
ELEVENLABS_USE_SPEAKER_BOOST=true
